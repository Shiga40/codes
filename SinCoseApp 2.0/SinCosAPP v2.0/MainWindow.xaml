<Window x:Class="SinCosAPP_v2._0.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        xmlns:res="clr-namespace:SinCosAPP_v2._0.Resources"
        Title="{x:Static res:Resources.AppTitle}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="10">
            <TextBlock x:Name="lblLanguage" Text="{x:Static res:Resources.LangLabel}" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox x:Name="cmbLanguage" Width="100" SelectionChanged="cmbLanguage_SelectionChanged">
                <ComboBoxItem Content="English" Tag="en"/>
                <ComboBoxItem Content="Русский" Tag="ru"/>
            </ComboBox>
        </StackPanel>

        <ScottPlot:WpfPlot x:Name="WpfPlot1" Grid.Row="1"/>
    </Grid>
</Window>