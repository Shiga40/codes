<Window x:Class="SineCosineAPP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        xmlns:res="clr-namespace:SineCosineAPP.Resources"
        Title="{x:Static res:Strings.AppTitle}" Height="550" Width="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="10">
            <Label Content="{x:Static res:Strings.LangLabel}" VerticalAlignment="Center"/>
            <ComboBox x:Name="cmbLanguage" Width="150" Margin="10,0" SelectionChanged="CmbLanguage_SelectionChanged">
                <ComboBoxItem Content="English" Tag="en-US"/>
                <ComboBoxItem Content="Русский" Tag="ru-RU"/>
            </ComboBox>
        </StackPanel>

        <ScottPlot:WpfPlot x:Name="WpfPlot1" Grid.Row="1" Margin="5"/>
    </Grid>
</Window>