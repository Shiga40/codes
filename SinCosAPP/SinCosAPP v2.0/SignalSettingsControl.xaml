<UserControl x:Class="SinCosAPP_v2._0.SignalSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             
             xmlns:lex="http://wpflocalizeextension.codeplex.com"
             lex:ResxLocalizationProvider.DefaultAssembly="SinCosAPP v2.0"
             lex:ResxLocalizationProvider.DefaultDictionary="Resources.Resources"
             
             d:DesignHeight="350" d:DesignWidth="220">

    <Border Background="White" CornerRadius="5" Padding="8" BorderBrush="LightGray" BorderThickness="1">
        <StackPanel>
            <TextBlock Text="{lex:Loc SettingsHeader}" 
                       FontWeight="Bold" 
                       FontSize="14"
                       Margin="0,0,0,10" 
                       TextWrapping="Wrap"
                       HorizontalAlignment="Left"/>

            <Label Content="{lex:Loc RangeX}" Padding="0,5,0,2"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtMinX" Text="0" Height="25" VerticalContentAlignment="Center"/>
                <TextBox x:Name="TxtMaxX" Grid.Column="2" Text="100" Height="25" VerticalContentAlignment="Center"/>
            </Grid>

            <Label Content="{lex:Loc AmplitudeY}" Margin="0,8,0,2" Padding="0"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtMinY" Text="-10" Height="25" VerticalContentAlignment="Center"/>
                <TextBox x:Name="TxtMaxY" Grid.Column="2" Text="10" Height="25" VerticalContentAlignment="Center"/>
            </Grid>

            <Label Content="{lex:Loc Count}" Margin="0,8,0,2" Padding="0"/>
            <TextBox x:Name="TxtCount" Text="50" Height="25" VerticalContentAlignment="Center"/>

            <Button x:Name="BtnApply" 
                    Content="{lex:Loc BtnApply}" 
                    Margin="0,15,0,0" 
                    Height="32" 
                    Background="#FF0040FF" 
                    Foreground="White"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="3"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button x:Name="BtnClear" 
                    Content="{lex:Loc BtnClear}" 
                    Margin="0,8,0,0" 
                    Height="32" 
                    Background="#FF0040FF" 
                    Foreground="White"
                    x:FieldModifier="public"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="3"/>
                    </Style>
                </Button.Resources>
            </Button>

        </StackPanel>
    </Border>
</UserControl>