<Window x:Class="SinCosAPP_v2._0.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        xmlns:lex="http://wpflocalizeextension.codeplex.com"
        xmlns:local="clr-namespace:SinCosAPP_v2._0" 
        lex:ResxLocalizationProvider.DefaultAssembly="SinCosAPP_v2._0"
        lex:ResxLocalizationProvider.DefaultDictionary="Resources"
        Title="Sin/Cos"
        Height="450" Width="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="10,10,10,10" Grid.ColumnSpan="2">
            <TextBlock x:Name="lblLanguage" 
                       Text="Language:"
                       VerticalAlignment="Center" 
                       Margin="0,0,10,0"/>

            <ComboBox x:Name="cmbLanguage" Width="120" SelectionChanged="cmbLanguage_SelectionChanged">
                <ComboBoxItem Tag="en">
                    <TextBlock x:Name="txtEnglish" Text="English"/>
                </ComboBoxItem>
                <ComboBoxItem Tag="ru">
                    <TextBlock x:Name="txtRussian" Text="Russian"/>
                </ComboBoxItem>
                <ComboBoxItem Tag="de">
                    <TextBlock x:Name="txtGerman" Text="German"/>
                </ComboBoxItem>
            </ComboBox>
        </StackPanel>

        <local:SignalSettingsControl x:Name="SettingsControl" Grid.Row="1" Grid.Column="0" Margin="5"/>

        <ScottPlot:WpfPlot x:Name="WpfPlot1" Grid.Row="1" Grid.Column="1"/>
    </Grid>
</Window>